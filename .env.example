# Copy to .env and adjust. Real environment variables override these.

# --- Connections ---
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/matchmaker
REDIS_URL=redis://127.0.0.1:6379
BIND=127.0.0.1:8080

# --- Auth ---
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_TTL_SECS=3600

# --- Redis cache TTLs (seconds) ---
STATUS_TTL_SECS=1800
PLAYER_CACHE_TTL_SECS=300

# --- Matcher tuning ---
NUM_BUCKETS=60
BUCKET_WIDTH=50
NUM_WORKERS=5
STRIDE=3

# --- Infrastructure ---
HTTP_WORKERS=2
PG_POOL_SIZE=16
REDIS_POOL_SIZE=16

SNAPSHOT_DIR=./snapshots
SNAPSHOT_INTERVAL_SECS=300
SNAPSHOTS_KEPT=3
